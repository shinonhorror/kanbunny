{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2023",
		"lib": ["ES2023"],
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"incremental": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"allowSyntheticDefaultImports": true
	}
}
